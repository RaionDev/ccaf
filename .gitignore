.fvm/
!.fvm/fvm_config.json

# ===== IDEs y editores =====
.idea/
.vscode/
*.iml
*.ipr
*.iws

# ===== Sistema operativo =====
.DS_Store
Thumbs.db
desktop.ini

# ===== Android (generados) =====
android/.gradle/
android/app/debug/
android/app/profile/
android/app/release/
android/local.properties
android/key.properties
*.jks
*.keystore

# ===== iOS (generados) =====
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/ephemeral/

# ===== Web =====
