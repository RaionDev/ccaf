# ===== Flutter / Dart =====
# Artefactos de compilación (Vercel los regenera; nunca se suben)
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
*.g.dart.bak

# ===== FVM =====
